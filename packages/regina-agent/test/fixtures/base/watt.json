{
  "$schema": "https://schemas.platformatic.dev/wattpm/2.0.0.json",
  "server": {
    "hostname": "127.0.0.1"
  },
  "logger": {
    "level": "debug"
  },
  "management": true,
  "entrypoint": "regina",
  "services": [
    {
      "id": "regina",
      "path": "./regina",
      "management": {
        "operations": ["addApplications", "removeApplications", "getApplications", "getApplicationDetails", "inject"]
      }
    }
  ],
  "restartOnError": false
}
